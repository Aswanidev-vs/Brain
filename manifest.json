{
  "manifest_version": 3,
  "name": "Brain",
  "version": "0.1.4",
  "description": "Capture AI chats from ChatGPT, Claude, Gemini, Grok. Store in Obsidian with graph connections.",
  "permissions": ["activeTab", "storage", "scripting", "tabs", "alarms"],
  "host_permissions": [
    "https://chat.openai.com/*", "https://chatgpt.com/*",
    "https://claude.ai/*", "https://gemini.google.com/*",
    "https://grok.com/*", "https://x.com/*",
    "http://127.0.0.1:27123/*", "https://127.0.0.1:27124/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background/service-worker.js" },
  "content_scripts": [
    { "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"], "js": ["content/platform.js"], "css": ["styles/capture-button.css"], "run_at": "document_idle" },
    { "matches": ["https://claude.ai/*"], "js": ["content/platform.js"], "css": ["styles/capture-button.css"], "run_at": "document_idle" },
    { "matches": ["https://gemini.google.com/*"], "js": ["content/platform.js"], "css": ["styles/capture-button.css"], "run_at": "document_idle" },
    { "matches": ["https://grok.com/*", "https://x.com/*"], "js": ["content/platform.js"], "css": ["styles/capture-button.css"], "run_at": "document_idle" }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}